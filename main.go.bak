package main

import (
	"fmt"
	"os"
	"os/signal"
	"syscall"

	"golang.org/x/term"
)

func main() {
	var amount int

	// Clear screen and move cursor to top-left
	fmt.Print("\033[2J") // Clear screen
	fmt.Print("\033[H")  // Move cursor to row 1, col 1

	// Print frame
	fmt.Printf("Game Simulation Program\n")
	fmt.Printf("\n")
	fmt.Printf("Set initial Amount: ")

	// Read initial amount normally (flush input)
	fmt.Scanln(&amount)

	fmt.Printf("\n")
	fmt.Printf("Press A to Increase amount by 100\n")
	fmt.Printf("Press B to Decrease amount by 100\n")
	fmt.Printf("Press Q to Quit\n")
	fmt.Printf("\n")
	fmt.Printf("Amount: %d\n", amount)
	fmt.Printf("What's your action: ")

	amountRow := 9
	promptRow := 10

	// Put terminal in raw mode for single-key input
	oldState, err := term.MakeRaw(int(os.Stdin.Fd()))
	if err != nil {
		panic(err)
	}
	defer term.Restore(int(os.Stdin.Fd()), oldState)

	// Handle Ctrl+C
	sig := make(chan os.Signal, 1)
	signal.Notify(sig, os.Interrupt, syscall.SIGTERM)
	go func() {
		<-sig
		term.Restore(int(os.Stdin.Fd()), oldState)
		fmt.Print("\033[H\033[2J") // clear screen on exit
		fmt.Println("Exiting...")
		os.Exit(0)
	}()

	for {
		var b [1]byte
		os.Stdin.Read(b[:])
		key := b[0]

		switch key {
		case 'A', 'a':
			amount += 100
		case 'B', 'b':
			amount -= 100
		case 'Q', 'q':
			fmt.Printf("\033[%d;1H\nExiting...\n", promptRow+1)
			return
		default:
			continue
		}

		// Update Amount line
		fmt.Printf("\033[%d;1H\033[2KAmount: %d", amountRow, amount)
		// Update prompt line
		fmt.Printf("\033[%d;1H\033[2KWhat's your action: ", promptRow)
	}
}
